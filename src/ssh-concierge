#!/bin/sh
# ssh-concierge: Match exec entry point
#
# Called by: Match host * exec "ssh-concierge %h"
# Always exits 0 — never blocks SSH connections.
#
# Hot path: stat the config file, check age < TTL → exit 0 (sub-millisecond)
# Cold path: invoke Python to regenerate from 1Password

# Any flag (--something / -x): delegate to Python (argparse handles errors)
# Only bare hostnames (from Match exec "ssh-concierge %h") fall through.
case "$1" in
    -*)
        ssh-concierge-py "$@"
        exit $?
        ;;
esac

# Read config values from Python (single source of truth)
CONFIG=$(ssh-concierge-py --config hosts_file 2>/dev/null)
TTL=$(ssh-concierge-py --config ttl 2>/dev/null)

# Fallback if Python fails (e.g. broken install)
if [ -z "$CONFIG" ]; then
    if [ -n "$XDG_RUNTIME_DIR" ]; then
        CONFIG="$XDG_RUNTIME_DIR/ssh-concierge/hosts.conf"
    else
        CONFIG="/tmp/ssh-concierge-$(id -u)/hosts.conf"
    fi
fi
TTL="${TTL:-3600}"

# Hot path: config exists and is fresh
if [ -f "$CONFIG" ]; then
    now=$(date +%s)
    mtime=$(stat -c %Y "$CONFIG" 2>/dev/null || stat -f %m "$CONFIG" 2>/dev/null || echo 0)
    age=$((now - mtime))
    if [ "$age" -lt "$TTL" ]; then
        exit 0
    fi
fi

# Cold path: regenerate (Python handles all 1Password interaction)
ssh-concierge-py --generate --quiet 2>/dev/null

# Always succeed — never block SSH connections
exit 0
