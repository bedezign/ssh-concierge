#!/bin/sh
# ssh-concierge: Match exec entry point
#
# Called by: Match host * exec "ssh-concierge %h"
# Always exits 0 — never blocks SSH connections.
#
# Hot path: stat the config file, check age < TTL → exit 0 (sub-millisecond)
# Cold path: invoke Python to regenerate from 1Password

if [ -n "$XDG_RUNTIME_DIR" ]; then
    RUNTIME_DIR="$XDG_RUNTIME_DIR/ssh-concierge"
else
    RUNTIME_DIR="/tmp/ssh-concierge-$(id -u)"
fi
readonly RUNTIME_DIR
readonly CONFIG="$RUNTIME_DIR/hosts.conf"
readonly TTL=3600  # 1 hour

# --generate / --flush / --list / --status: delegate to Python immediately
case "$1" in
    --generate|--flush|--list|--status|--debug|--deploy-key|--help|-h)
        ssh-concierge-py "$@"
        exit $?
        ;;
esac

# Hot path: config exists and is fresh
if [ -f "$CONFIG" ]; then
    now=$(date +%s)
    mtime=$(stat -c %Y "$CONFIG" 2>/dev/null || stat -f %m "$CONFIG" 2>/dev/null || echo 0)
    age=$((now - mtime))
    if [ "$age" -lt "$TTL" ]; then
        exit 0
    fi
fi

# Cold path: regenerate (Python handles all 1Password interaction)
ssh-concierge-py --generate --quiet 2>/dev/null

# Always succeed — never block SSH connections
exit 0
